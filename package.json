{
  "name": "project-graveyard",
  "version": "0.1.2",
  "description": "给未完成的项目一个体面的结局。",
  "main": "dist-electron/electron/main.js",
  "author": "Project Graveyard contributors",
  "license": "MIT",
  "scripts": {
    "dev": "npm run build:electron && concurrently -k \"vite\" \"tsc -p tsconfig.electron.json --watch\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "web:dev": "vite",
    "web:build": "vite build",
    "web:preview": "vite preview",
    "clean:electron": "node -e \"require('fs').rmSync('dist-electron',{recursive:true,force:true})\"",
    "build:electron": "npm run clean:electron && tsc -p tsconfig.electron.json",
    "build": "npm run build:electron && vite build",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "lint": "eslint src electron vite.config.ts vitest.config.ts --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "dist:win": "npm run build && electron-builder --win nsis --publish never",
    "dist:dir": "npm run build && electron-builder --dir"
  },
  "dependencies": {
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "latest",
    "concurrently": "latest",
    "cross-env": "latest",
    "electron": "latest",
    "electron-builder": "latest",
    "eslint": "latest",
    "eslint-plugin-react-hooks": "latest",
    "eslint-plugin-react-refresh": "latest",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest",
    "vite": "latest",
    "vitest": "latest",
    "wait-on": "latest"
  },
  "build": {
    "appId": "dev.projectgraveyard.app",
    "productName": "Project Graveyard",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "asar": true,
    "compression": "maximum",
    "electronLanguages": [
      "en-US",
      "zh-CN"
    ],
    "win": {
      "icon": "public/graveyard.svg",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Project-Graveyard-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
